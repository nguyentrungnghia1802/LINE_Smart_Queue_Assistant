{
  "name": "@line-queue/api",
  "version": "0.0.1",
  "private": true,
  "description": "Express REST API for LINE Smart Queue Assistant",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc --build",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "clean": "rimraf dist *.tsbuildinfo",
    "db:migrate": "node-pg-migrate up --migration-file-language ts --tsconfig tsconfig.json --migrations-dir ../../db/migrations/node-pg-migrate",
    "db:migrate:down": "node-pg-migrate down --migration-file-language ts --tsconfig tsconfig.json --migrations-dir ../../db/migrations/node-pg-migrate",
    "db:migrate:redo": "npm run db:migrate:down && npm run db:migrate",
    "db:migrate:status": "node-pg-migrate status --migration-file-language ts --tsconfig tsconfig.json --migrations-dir ../../db/migrations/node-pg-migrate",
    "db:seed": "ts-node --project tsconfig.json ../../db/seeds/index.ts",
    "db:seed:reset": "ts-node --project tsconfig.json ../../db/seeds/index.ts --reset"
  },
  "dependencies": {
    "@line-queue/shared": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@line-queue/config": "*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^5.0.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
