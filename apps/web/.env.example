# ──────────────────────────────────────────────────────────────────────────────
# apps/web — Environment variable reference
#
# Copy this file to .env.local for local development.
# Never commit real secrets or LIFF IDs to source control.
# ──────────────────────────────────────────────────────────────────────────────


# ── App ────────────────────────────────────────────────────────────────────────

# Optional backend origin, without a trailing slash.
# Keep it empty for production same-origin nginx proxying because requests
# already include /api/v1. Set an origin only when the API is on another host.
# Local Vite development proxies /api/* to the backend on port 4000.
VITE_API_URL=

# Display name shown in the app header.
VITE_APP_NAME=LINE Queue

# Local/test only. Production builds should keep this false so customers enter
# through LINE instead of creating legacy email/password accounts.
VITE_ENABLE_LEGACY_CUSTOMER_AUTH=true


# ── Payment ───────────────────────────────────────────────────────────────────
#
# Default/blank keeps the current demo checkout: payment succeeds automatically.
# Set VITE_PAYMENT_MODE=external only after signing up with a provider/gateway
# and preparing a redirect endpoint that accepts session_id, amount, currency,
# method and return_url query parameters.
VITE_PAYMENT_MODE=demo
VITE_PAYMENT_REDIRECT_BASE_URL=


# ── LIFF — Production ──────────────────────────────────────────────────────────
#
# How to obtain a LIFF ID:
#   1. Go to https://developers.line.biz/console/
#   2. Select (or create) a provider → select your channel → LIFF tab.
#   3. Create a new LIFF app, set the Endpoint URL to your production domain.
#   4. Copy the LIFF ID (format: 1234567890-AbCdEfGh).
#
# Required in production. This public ID is compiled into the web image and
# must match the backend LINE_LIFF_ID. Ignored when VITE_LIFF_MOCK=true.
VITE_LIFF_ID=
VITE_LIFF_DEFAULT_BOOKING_PATH=/liff/qr/demo-queue-lab-2026


# ── LIFF — Local development (mock mode) ──────────────────────────────────────
#
# Set VITE_LIFF_MOCK=true to bypass the real LINE SDK entirely.
# The MockLiffAdapter simulates login state and returns fake profile data,
# letting you develop and test UI locally without a LINE account or internet.
#
# Recommended .env.local for local development:
#   VITE_LIFF_MOCK=true
#   VITE_LIFF_MOCK_LOGGED_IN=true   # true = start logged in, false = logged out
#
# All VITE_LIFF_MOCK_* vars below are optional and have sensible defaults.

# Enable mock adapter (set to "true" for local dev, leave blank/false for prod).
VITE_LIFF_MOCK=false

# Whether the mock session starts in a logged-in state.
# Set to "false" to test the unauthenticated / sign-in flow.
# Default: true
VITE_LIFF_MOCK_LOGGED_IN=true

# Fake LINE userId returned by the mock adapter.
# Default: mock-user-001
VITE_LIFF_MOCK_USER_ID=mock-user-001

# Fake display name shown in the app header and profile card.
# Default: Dev User
VITE_LIFF_MOCK_DISPLAY_NAME=Dev User

# URL of the avatar image used in the mock profile.
# Default: a placehold.co placeholder (no external dependency required).
VITE_LIFF_MOCK_PICTURE_URL=https://placehold.co/96x96/06c755/ffffff?text=DEV

# Artificial initialisation delay in milliseconds.
# Simulates real LIFF SDK latency so loading states are visible during dev.
# Set to 0 to skip the delay.  Default: 400
VITE_LIFF_MOCK_INIT_DELAY_MS=400
