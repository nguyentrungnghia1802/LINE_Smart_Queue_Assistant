# Copy to deploy/.env on the deployment host. Never commit the populated file.

# Immutable images built from the same reviewed commit.
# The web image must be built with an empty VITE_API_URL and production LIFF values.
LINE_QUEUE_API_IMAGE=your-registry/line-smart-queue-api:replace-with-release-tag
LINE_QUEUE_WEB_IMAGE=your-registry/line-smart-queue-web:replace-with-release-tag

# Public web endpoint exposed by the web/nginx container.
WEB_ORIGIN=https://queue.example.com
WEB_PORT=80

# PostgreSQL. DATABASE_URL is assembled inside Compose from these values.
DB_NAME=line_queue
DB_USER=line_queue
DB_PASSWORD=replace-with-a-strong-database-password

# API runtime.
NODE_ENV=production
API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET=replace-with-a-64-byte-random-secret
JWT_EXPIRES_IN=7d

# LINE Login and Messaging API. Keep secrets only in this deployment file or
# the deployment platform's secret manager.
LINE_CHANNEL_ID=replace-with-line-login-channel-id
LINE_ID_TOKEN_VERIFICATION_MODE=line
LINE_CHANNEL_SECRET=replace-with-messaging-api-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=replace-with-messaging-api-channel-access-token
# This LIFF ID must also be passed as VITE_LIFF_ID when building the web image.
# It is public configuration, but it is compiled into the image and cannot be
# changed by docker compose after the image has been pushed.
LINE_LIFF_ID=replace-with-liff-id
LINE_RICH_MENU_IMAGE_PATH=

# Durable LINE notification delivery.
LINE_NOTIFICATION_BATCH_SIZE=20
LINE_NOTIFICATION_WORKER_INTERVAL_MS=15000
LINE_NOTIFICATION_MAX_ATTEMPTS=5
LINE_NOTIFICATION_RETRY_BASE_SECONDS=30
LINE_NOTIFICATION_PROCESSING_TIMEOUT_SECONDS=300

# Payment foundation. Demo remains the supported provider until a PSP adapter
# is configured.
PAYMENT_MODE=demo
DEMO_PAYMENT_WEBHOOK_SECRET=replace-with-a-dedicated-random-secret
PAYMENT_WEBHOOK_MAX_AGE_SECONDS=300
PAYMENT_EXTERNAL_REDIRECT_BASE_URL=

# Inventory, location alerts, and forecasting workers.
INVENTORY_RESERVATION_TTL_MINUTES=1440
INVENTORY_EXPIRY_BATCH_SIZE=100
INVENTORY_EXPIRY_WORKER_INTERVAL_MS=60000
LOCATION_RETENTION_DAYS=30
LOCATION_ALERT_BATCH_SIZE=50
LOCATION_ALERT_MAX_ATTEMPTS=5
LOCATION_CLEANUP_BATCH_SIZE=500
LOCATION_WORKER_INTERVAL_MS=60000
LOCATION_CLEANUP_INTERVAL_MS=3600000
FORECAST_RETENTION_DAYS=90
FORECAST_WORKER_INTERVAL_MS=3600000

# Local media is persisted in the media_data volume. Replace this boundary with
# object storage before a production launch that requires durable external media.
MEDIA_STORAGE_MODE=local
MEDIA_LOCAL_DIR=/app/var/media
MEDIA_PUBLIC_BASE_URL=/media
MEDIA_MAX_ORIGINAL_BYTES=5242880
MEDIA_REQUEST_BODY_LIMIT=8mb
