{
  "name": "line-smart-queue",
  "version": "0.0.1",
  "private": true,
  "description": "LINE Smart Queue Assistant — production-ready monorepo",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build -w packages/shared && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "spell:check": "cspell \"**/*.{ts,tsx,md}\" --no-progress --show-context",
    "clean": "npm run clean --workspaces --if-present",
    "prepare": "npm run build -w packages/shared && husky",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:d": "docker compose -f docker-compose.dev.yml up --build -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:dev:ps": "docker compose -f docker-compose.dev.yml ps",
    "docker:prod": "docker compose up --build",
    "docker:prod:d": "docker compose up --build -d",
    "docker:prod:down": "docker compose down",
    "docker:clean": "docker compose -f docker-compose.dev.yml down --volumes --remove-orphans",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:migrate:down": "npm run db:migrate:down -w apps/api",
    "db:migrate:redo": "npm run db:migrate:redo -w apps/api",
    "db:migrate:status": "npm run db:migrate:status -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "db:seed:reset": "npm run db:seed:reset -w apps/api"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@line-queue/config": "*",
    "cspell": "^8.9.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5"
  }
}
