# ─────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/line_queue
DB_HOST=localhost
DB_PORT=5432
DB_NAME=line_queue
DB_USER=postgres
DB_PASSWORD=password

# ─────────────────────────────────────────
# API Server
# ─────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────
# Auth
# ─────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────
# LINE Messaging API
# ─────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ─────────────────────────────────────────
# Web (Vite exposes VITE_* to the browser)
# ─────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_APP_NAME=LINE Smart Queue Assistant
