# ══════════════════════════════════════════════════════════════════════════════
# LINE Smart Queue Assistant — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Variable naming conventions:
#   DB_*       — PostgreSQL connection settings
#   API_*      — Express server configuration
#   JWT_*      — Auth token settings  (⚠️ backend-only, never expose)
#   LINE_*     — LINE platform credentials  (⚠️ backend-only, never expose)
#   VITE_*     — Frontend vars (⚠️ inlined into the browser bundle at Vite build time)
#   WEB_*      — Web container / nginx settings
#
# Docker Compose notes:
#   - docker-compose.yml (prod)    uses DB_PASSWORD with :? — it MUST be set
#   - docker-compose.dev.yml (dev) falls back to "dev_password" for convenience
#   - VITE_* are passed as build ARGs in docker-compose.yml; dev reads them at startup

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# DATABASE_URL is built dynamically by docker-compose from DB_* vars.
# Set it directly here only when connecting outside of docker-compose.
DATABASE_URL=postgresql://postgres:change_me@localhost:5432/line_queue

DB_HOST=localhost
DB_PORT=5432
DB_NAME=line_queue
DB_USER=postgres
# ⚠️ Required in production (docker-compose.yml fails fast if unset)
DB_PASSWORD=change_me

# ── API Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────────────
# ⚠️ Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-64-byte-random-hex-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── LINE Login / LIFF server verification ───────────────────────────────────
# LINE Login channel ID used to verify LIFF OIDC ID tokens.
LINE_CHANNEL_ID=2010516188

# ── LINE Messaging API ───────────────────────────────────────────────────────
# Messaging API channel secret and access token. These belong to the Official
# Account channel, not the LINE Login channel. Keep both only in .env.
LINE_CHANNEL_SECRET=change_me
LINE_CHANNEL_ACCESS_TOKEN=

# Durable LINE notification outbox worker. Non-secret operational tuning.
LINE_NOTIFICATION_BATCH_SIZE=20
LINE_NOTIFICATION_WORKER_INTERVAL_MS=15000
LINE_NOTIFICATION_MAX_ATTEMPTS=5
LINE_NOTIFICATION_RETRY_BASE_SECONDS=30
LINE_NOTIFICATION_PROCESSING_TIMEOUT_SECONDS=300

# ── LIFF (LINE Front-end Framework) ─────────────────────────────────────────
# LIFF App ID from LINE Developers Console
# This is safe to expose (it identifies, not authenticates)
# LIFF URL: https://liff.line.me/2010516188-KAcYkLTh
VITE_LIFF_ID=2010516188-KAcYkLTh
# Same LIFF App ID for backend-generated LINE notification deep links.
LINE_LIFF_ID=2010516188-KAcYkLTh
# Optional PNG/JPEG image path used only by `npm run line:rich-menu:sync`.
# For production LINE sync, provide a real Rich Menu image that matches the definition size.
LINE_RICH_MENU_IMAGE_PATH=

# ── LIFF local development (mock mode) ───────────────────────────────────────
# Set VITE_LIFF_MOCK=true to bypass the real LINE SDK during local development.
# The mock adapter simulates LINE login so you can work without a real LIFF app.
VITE_LIFF_MOCK=true
VITE_LIFF_MOCK_LOGGED_IN=true
# VITE_LIFF_MOCK_USER_ID=mock-user-001
# VITE_LIFF_MOCK_DISPLAY_NAME=Dev User
# VITE_LIFF_MOCK_PICTURE_URL=https://placehold.co/96x96/06c755/ffffff?text=DEV
# VITE_LIFF_MOCK_INIT_DELAY_MS=400

# ── Web / Frontend ───────────────────────────────────────────────────────────
# ⚠️ VITE_* vars are embedded into the JS bundle at build time.
#    They are visible to anyone who downloads your app. Never put secrets here.
VITE_API_URL=http://127.0.0.1:4000
VITE_APP_NAME=LINE Smart Queue Assistant
VITE_LIFF_DEFAULT_BOOKING_PATH=/liff/qr/demo-queue-lab-2026
VITE_PAYMENT_MODE=demo
VITE_PAYMENT_REDIRECT_BASE_URL=

# ── Payment provider foundation (backend-only) ───────────────────────────────
PAYMENT_MODE=demo
PAYMENT_EXTERNAL_REDIRECT_BASE_URL=
DEMO_PAYMENT_WEBHOOK_SECRET=change_me_to_a_random_demo_payment_secret
PAYMENT_WEBHOOK_MAX_AGE_SECONDS=300

# Finite inventory reservations. Set TTL to 0 to disable automatic expiry.
INVENTORY_RESERVATION_TTL_MINUTES=1440
INVENTORY_EXPIRY_BATCH_SIZE=100
INVENTORY_EXPIRY_WORKER_INTERVAL_MS=60000

# Location is snapshot-only. No continuous tracking or paid travel API is used.
LOCATION_RETENTION_DAYS=30
LOCATION_ALERT_BATCH_SIZE=50
LOCATION_ALERT_MAX_ATTEMPTS=5
LOCATION_CLEANUP_BATCH_SIZE=500
LOCATION_WORKER_INTERVAL_MS=60000
LOCATION_CLEANUP_INTERVAL_MS=3600000

# Measured heuristic forecasting (no external AI service)
FORECAST_RETENTION_DAYS=90
FORECAST_WORKER_INTERVAL_MS=3600000

# Media storage. local/mock are implemented; real object storage remains an adapter boundary.
MEDIA_STORAGE_MODE=local
MEDIA_LOCAL_DIR=../../../../var/media
MEDIA_PUBLIC_BASE_URL=/media
MEDIA_MAX_ORIGINAL_BYTES=5242880
MEDIA_REQUEST_BODY_LIMIT=8mb

# ── Web container (Docker) ───────────────────────────────────────────────────
WEB_PORT=80
# Used by docker-compose.yml for CORS_ORIGIN on the api service
WEB_ORIGIN=http://localhost:80

# ── Node.js debugger (dev only) ──────────────────────────────────────────────
# Port exposed by docker-compose.dev.yml for Node inspector
# Attach via VS Code "Node.js: Attach" launch config or chrome://inspect
NODE_INSPECTOR_PORT=9229
